# Project
PROJECT_NAME="Plotify Messaging Engine"

# Redis
REDIS_URL="redis://localhost:6379/0"

# Supabase
SUPABASE_URL="http://127.0.0.1:8000"
SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key"
# Local Docker: usa el pooler local del stack `supabase-pooler`.
SUPABASE_DB_URL="postgresql://postgres.your-tenant-id:tu-password-local@localhost:6543/postgres"
# Hosted Supabase en redes sin IPv6: copia el Shared/Transaction Pooler desde Dashboard > Connect.
# Ejemplo: postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?sslmode=require
CHECKPOINTER_CONNECT_TIMEOUT_SECONDS=5
# Dev: false permite fallback a memoria si Postgres no está disponible.
# Producción/staging con conversaciones persistentes: true.
CHECKPOINTER_REQUIRED=false

# Meta (WhatsApp)
META_VERIFY_TOKEN="tu-token-de-verificacion-webhook"
META_ACCESS_TOKEN="tu-token-api-meta"

# LLM Providers
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."

# API Settings
API_PORT=8005
# URL pública expuesta por ngrok/tunnel para recibir webhooks de Telegram
API_PUBLIC_URL="https://api.plotify.demo"
FRONTEND_URL="http://localhost:3000"
INTERNAL_API_SECRET="your-shared-secret-here"
