# Project
PROJECT_NAME="Plotify Messaging Engine"

# Redis
REDIS_URL="redis://localhost:6379/0"

# Supabase
SUPABASE_URL="http://127.0.0.1:8000"
SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key"
# Pooler local del stack Docker existente `supabase-pooler`.
SUPABASE_DB_URL="postgresql://postgres.your-tenant-id:tu-password-local@localhost:6543/postgres"

# Meta (WhatsApp)
META_VERIFY_TOKEN="tu-token-de-verificacion-webhook"
META_ACCESS_TOKEN="tu-token-api-meta"

# Telegram (Opcional)
TELEGRAM_BOT_TOKEN="tu-token-bot-telegram"

# LLM Providers
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."

# API Settings
API_PORT=8005
FRONTEND_URL="http://localhost:3000"
INTERNAL_API_SECRET="your-shared-secret-here"
