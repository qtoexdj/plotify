                  {
                    "type": "variable_token",
                    "attrs": {
                      "variableKey": "servidumbre.deslindes_tramo",
                      "label": "Deslindes del tramo de servidumbre"
                    }
                  },
                  {
                    "type": "text",
                    "text": ". El comprador acepta expresamente la servidumbre, su ubicación, extensión, destino y cargas."
                  }
                ]
              }
            ]
          }
        ]
      }
    },
