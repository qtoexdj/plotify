              {
                "type": "text",
                "text": ", según antecedentes que constan en los certificados conservatorios vigentes tenidos a la vista para esta operación. "
              },
              {
                "type": "variable_token",
                "attrs": {
                  "variableKey": "evidencia.certificado_gp_referencia",
                  "label": "Referencia certificado GP"
                }
              }
            ]
          }
        ]
      }
    },
