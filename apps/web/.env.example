
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Feature Flags
NEXT_PUBLIC_ENABLE_CAD_UPLOAD=false
ENABLE_CAD_UPLOAD=false

# Microservicio plotify_chat — solo la base URL (el código construye el path)
PLOTIFY_CHAT_BASE_URL=http://127.0.0.1:8005

# Telegram Bot User for Deep Linking
NEXT_PUBLIC_TELEGRAM_BOT_USER=plotify_chat_bot

# Secret compartido entre Next.js y el microservicio (generar con: openssl rand -hex 32)
INTERNAL_API_SECRET=your-shared-secret-here
