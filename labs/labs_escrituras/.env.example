# Direct DB connection for local Supabase Docker.
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Required to expose the local-only web lab routes.
PLOTIFY_ENABLE_ESCRITURAS_LAB=true

# Storage/API access for optional downloads/uploads from Python.
SUPABASE_URL=http://127.0.0.1:8000
SUPABASE_SERVICE_ROLE_KEY=replace-me

# Optional external tools.
PDF_INSPECTOR_COMMAND=pdf2md
LAB_OCR_ENABLED=true
LAB_OCR_LANGUAGE=spa+eng
LAB_OCR_DPI=220
OPENAI_API_KEY=
LAB_EMBEDDING_MODEL=text-embedding-3-small
LAB_EMBEDDING_BATCH_SIZE=64

# MCP server. stdio is the recommended transport for Codex, Claude Desktop,
# Antigravity, and other local agent clients.
LAB_MCP_TRANSPORT=stdio
LAB_MCP_HOST=127.0.0.1
LAB_MCP_PORT=8765
